{
  "name": "stock-predict-web",
  "version": "1.0.0",
  "description": "股票拐点预测工具 - Web 版本",
  "main": "dist-server/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx server/index.ts",
    "build": "tsc && vite build",
    "build:server": "tsx build/server.ts",
    "start": "node dist-server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["stock", "prediction", "web"],
  "author": "温浩明",
  "license": "MIT",
  "dependencies": {
    "antd": "^5.12.0",
    "@ant-design/icons": "^5.2.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^9.2.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.0",
    "express": "^4.18.2",
    "lightweight-charts": "^4.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}